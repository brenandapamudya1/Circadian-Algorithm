{
  "expo": {
    "name": "Bypolizer",
    "slug": "bypolizer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon_app.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.bipolyzer.circadian",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/icon_app.png"
    },
    "extra": {
      "eas": {
        "projectId": "dc6a92ec-7ac0-4383-b4a6-cb6bbf6bef71"
      }
    },
    "plugins": [
      "expo-sqlite",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": [
            "peripheral",
            "central"
          ],
          "bluetoothNeverForLocationPermissionDescription": "Aplikasi Bypolizer membutuhkan Bluetooth untuk terhubung ke sensor sirkadian."
        }
      ]
    ]
  }
}
